# ── PitchKey waitlist API (app/api/waitlist/route.ts) ──────────────────────
# Copy to .env.local for local dev, and set the same keys in the Vercel
# dashboard (Project → Settings → Environment Variables) for production.

# Resend — email delivery. Get a key at https://resend.com (free tier).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where signup notifications are sent (your inbox).
WAITLIST_NOTIFY_EMAIL=you@example.com

# Optional — the "From" address. Defaults to Resend's onboarding sender, which
# works with no setup. Once you verify your own domain in Resend, set this to
# e.g. "PitchKey <hello@yourdomain.com>".
# RESEND_FROM=PitchKey Waitlist <onboarding@resend.dev>

# Upstash Redis — per-IP rate limiting. Create a free database at
# https://console.upstash.com and copy the REST URL + token.
UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
